{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zmos.dev/schemas/trace.record.schema.json",
  "title": "Z-MOS v2.0 Trace Integrity Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sequence_id",
    "timestamp",
    "event_type",
    "contract_hash",
    "gate",
    "actor",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence_id": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "gate": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "enum": [
        "human",
        "system",
        "codex",
        "agent"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "warning",
        "blocked",
        "failed"
      ]
    },
    "prev_hash": {
      "type": "string",
      "minLength": 1
    },
    "record_hash": {
      "type": "string",
      "minLength": 1
    },
    "details": {
      "type": "object"
    }
  }
}
