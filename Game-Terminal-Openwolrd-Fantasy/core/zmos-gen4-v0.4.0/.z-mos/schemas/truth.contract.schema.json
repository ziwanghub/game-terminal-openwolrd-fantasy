{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://zmos.dev/schemas/truth.contract.schema.json",
  "title": "Z-MOS v2.0 Truth Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "code_ref",
    "runtime_ref",
    "env_ref",
    "data_ref",
    "asset_ref",
    "gate_state",
    "confidence",
    "unknowns",
    "verdict"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "code_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit",
        "branch"
      ],
      "properties": {
        "commit": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "process"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "process": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "env_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_host",
        "target_env",
        "config_hash"
      ],
      "properties": {
        "target_host": {
          "type": "string",
          "minLength": 1
        },
        "target_env": {
          "type": "string",
          "minLength": 1
        },
        "config_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "data_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "schema_hash"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "schema_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "asset_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_hash",
        "cache_hash"
      ],
      "properties": {
        "bundle_hash": {
          "type": "string",
          "minLength": 1
        },
        "cache_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gate_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_gate",
        "required_checks"
      ],
      "properties": {
        "active_gate": {
          "type": "string",
          "minLength": 1
        },
        "required_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "SAFE_TO_CONTINUE",
        "BLOCKED",
        "STALE",
        "CONFLICTED",
        "UNKNOWN"
      ]
    }
  }
}
